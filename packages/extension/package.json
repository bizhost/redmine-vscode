{
  "name": "redmine-vscode",
  "displayName": "Redmine Issues",
  "description": "Redmine 일감 목록/상세/상태변경/댓글",
  "version": "0.1.0",
  "private": true,
  "publisher": "konat",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "redmine",
          "title": "Redmine",
          "icon": "$(checklist)"
        }
      ]
    },
    "views": {
      "redmine": [
        {
          "id": "redmineIssues",
          "name": "일감"
        }
      ]
    },
    "commands": [
      {
        "command": "redmine.refresh",
        "title": "Redmine: 새로고침",
        "icon": "$(refresh)"
      },
      {
        "command": "redmine.setApiKey",
        "title": "Redmine: Set API Key"
      },
      {
        "command": "redmine.openIssue",
        "title": "Redmine: 일감 열기"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "redmine.refresh",
          "when": "view == redmineIssues",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Redmine",
      "properties": {
        "redmine.url": {
          "type": "string",
          "default": "",
          "description": "Redmine 서버 URL (https://...)"
        },
        "redmine.projectIdentifier": {
          "type": "string",
          "default": "",
          "description": "프로젝트 identifier (선택, 생략 시 전체 프로젝트)"
        },
        "redmine.assignedToMe": {
          "type": "boolean",
          "default": true,
          "description": "내게 할당된 일감만 표시"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@redmine-tools/core": "*"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  }
}
