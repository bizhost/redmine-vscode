{
  "name": "redmine-vscode",
  "displayName": "Redmine Issues",
  "description": "Redmine 일감 관리 — 목록/검색/상세/편집/댓글/첨부/다운로드",
  "version": "0.14.2",
  "publisher": "bizhost",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bizhost/redmine-vscode"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "redmine",
    "issue",
    "일감",
    "이슈",
    "project management"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "redmine",
          "title": "Redmine",
          "icon": "$(checklist)"
        }
      ]
    },
    "views": {
      "redmine": [
        {
          "id": "redmineMyIssues",
          "name": "내 일감",
          "type": "webview"
        },
        {
          "id": "redmineProjects",
          "name": "프로젝트",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "redmine.refresh",
        "title": "Redmine: 새로고침",
        "icon": "$(refresh)"
      },
      {
        "command": "redmine.searchMyIssues",
        "title": "Redmine: 내 일감 검색",
        "icon": "$(search)"
      },
      {
        "command": "redmine.searchProjects",
        "title": "Redmine: 프로젝트 일감 검색",
        "icon": "$(search)"
      },
      {
        "command": "redmine.newIssue",
        "title": "Redmine: 새 일감",
        "icon": "$(add)"
      },
      {
        "command": "redmine.setApiKey",
        "title": "Redmine: Set API Key"
      },
      {
        "command": "redmine.openIssue",
        "title": "Redmine: 일감 열기"
      },
      {
        "command": "redmine.openIssueInBrowser",
        "title": "Redmine: 브라우저에서 열기",
        "icon": "$(link-external)"
      },
      {
        "command": "redmine.issuesForFile",
        "title": "Redmine: 이 파일 관련 일감"
      },
      {
        "command": "redmine.downloadIssues",
        "title": "일감 다운로드 (issue.md + 첨부)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "redmine.newIssue",
          "when": "view == redmineMyIssues || view == redmineProjects",
          "group": "navigation"
        },
        {
          "command": "redmine.refresh",
          "when": "view == redmineMyIssues || view == redmineProjects",
          "group": "navigation"
        },
        {
          "command": "redmine.searchMyIssues",
          "when": "view == redmineMyIssues",
          "group": "navigation"
        },
        {
          "command": "redmine.searchProjects",
          "when": "view == redmineProjects",
          "group": "navigation"
        }
      ],
      "webview/context": [
        {
          "command": "redmine.openIssueInBrowser",
          "when": "webviewSection == 'issue'"
        },
        {
          "command": "redmine.downloadIssues",
          "when": "webviewSection == 'issue'"
        }
      ],
      "explorer/context": [
        {
          "command": "redmine.issuesForFile",
          "when": "!explorerResourceIsFolder",
          "group": "redmine"
        }
      ],
      "editor/context": [
        {
          "command": "redmine.issuesForFile",
          "group": "redmine"
        }
      ],
      "commandPalette": [
        {
          "command": "redmine.openIssue",
          "when": "false"
        },
        {
          "command": "redmine.openIssueInBrowser",
          "when": "false"
        },
        {
          "command": "redmine.downloadIssues",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Redmine",
      "properties": {
        "redmine.url": {
          "type": "string",
          "default": "",
          "description": "Redmine 서버 URL (https://...)"
        },
        "redmine.projectIdentifier": {
          "type": "string",
          "default": "",
          "description": "프로젝트 identifier (선택, '내 일감' 범위 한정용)"
        },
        "redmine.downloadPath": {
          "type": "string",
          "default": "",
          "description": "일감 다운로드 기본 경로. 절대경로/~ 또는 상대경로(워크스페이스 기준). 비우면 매번 위치 선택"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@redmine-tools/core": "*"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  }
}
