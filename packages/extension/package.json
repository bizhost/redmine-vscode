{
  "name": "redmine-vscode",
  "displayName": "Redmine Issues",
  "description": "Redmine 일감 목록/상세/상태변경/댓글",
  "version": "0.5.2",
  "private": true,
  "publisher": "konat",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "redmine",
          "title": "Redmine",
          "icon": "$(checklist)"
        }
      ]
    },
    "views": {
      "redmine": [
        {
          "id": "redmineSearch",
          "name": "검색",
          "type": "webview"
        },
        {
          "id": "redmineMyIssues",
          "name": "내 일감"
        },
        {
          "id": "redmineProjects",
          "name": "프로젝트"
        }
      ]
    },
    "commands": [
      {
        "command": "redmine.refresh",
        "title": "Redmine: 새로고침",
        "icon": "$(refresh)"
      },
      {
        "command": "redmine.search",
        "title": "Redmine: 일감 검색",
        "icon": "$(search)"
      },
      {
        "command": "redmine.setApiKey",
        "title": "Redmine: Set API Key"
      },
      {
        "command": "redmine.openIssue",
        "title": "Redmine: 일감 열기"
      },
      {
        "command": "redmine.loadMoreMy",
        "title": "Redmine: 더 보기 (내 일감)"
      },
      {
        "command": "redmine.loadMoreProject",
        "title": "Redmine: 더 보기 (프로젝트)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "redmine.refresh",
          "when": "view == redmineMyIssues || view == redmineProjects",
          "group": "navigation"
        },
        {
          "command": "redmine.search",
          "when": "view == redmineMyIssues || view == redmineProjects",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "redmine.openIssue",
          "when": "false"
        },
        {
          "command": "redmine.loadMoreMy",
          "when": "false"
        },
        {
          "command": "redmine.loadMoreProject",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Redmine",
      "properties": {
        "redmine.url": {
          "type": "string",
          "default": "",
          "description": "Redmine 서버 URL (https://...)"
        },
        "redmine.projectIdentifier": {
          "type": "string",
          "default": "",
          "description": "프로젝트 identifier (선택, '내 일감' 범위 한정용)"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@redmine-tools/core": "*"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  }
}
