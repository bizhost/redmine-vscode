{
  "name": "redmine-vscode",
  "displayName": "Redmine Issues",
  "description": "Redmine 일감 관리 — 목록/검색/상세/편집/댓글/첨부/다운로드",
  "version": "1.1.0",
  "publisher": "bizhost",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bizhost/redmine-vscode"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "redmine",
    "issue",
    "일감",
    "이슈",
    "project management"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "redmine",
          "title": "Redmine",
          "icon": "$(checklist)"
        }
      ],
      "panel": [
        {
          "id": "redminePanelContainer",
          "title": "Redmine",
          "icon": "$(checklist)"
        }
      ]
    },
    "views": {
      "redmine": [
        {
          "id": "redmineMyIssues",
          "name": "내 일감"
        },
        {
          "id": "redmineProjects",
          "name": "프로젝트"
        }
      ],
      "redminePanelContainer": [
        {
          "id": "redminePanel",
          "name": "워크벤치",
          "type": "webview"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "redmineMyIssues",
        "when": "!redmine:connected",
        "contents": "Redmine 서버에 연결하세요.\n서버 URL을 설정하면 일감을 불러옵니다.\n[서버 URL 설정](command:workbench.action.openSettings?%5B%22redmine.url%22%5D)"
      },
      {
        "view": "redmineMyIssues",
        "when": "redmine:connected && !redmine:authenticated",
        "contents": "API 키가 없거나 인증에 실패했습니다.\nRedmine 개인 API 키를 등록하세요.\n[API 키 입력](command:redmine.setApiKey)\n[서버 URL 확인](command:workbench.action.openSettings?%5B%22redmine.url%22%5D)"
      },
      {
        "view": "redmineMyIssues",
        "when": "redmine:connected && redmine:authenticated && !redmine:loading && !redmine:loadError",
        "contents": "할당된 일감이 없습니다.\n[+ 새 일감 만들기](command:redmine.newIssue)\n[# 번호로 열기](command:redmine.openIssueByNumber)"
      },
      {
        "view": "redmineProjects",
        "when": "!redmine:connected",
        "contents": "Redmine 서버에 연결하세요.\n서버 URL을 설정하면 일감을 불러옵니다.\n[서버 URL 설정](command:workbench.action.openSettings?%5B%22redmine.url%22%5D)"
      },
      {
        "view": "redmineProjects",
        "when": "redmine:connected && !redmine:authenticated",
        "contents": "API 키가 없거나 인증에 실패했습니다.\nRedmine 개인 API 키를 등록하세요.\n[API 키 입력](command:redmine.setApiKey)\n[서버 URL 확인](command:workbench.action.openSettings?%5B%22redmine.url%22%5D)"
      }
    ],
    "commands": [
      {
        "command": "redmine.refresh",
        "title": "Redmine: 새로고침",
        "icon": "$(refresh)"
      },
      {
        "command": "redmine.searchMyIssues",
        "title": "Redmine: 내 일감 검색",
        "icon": "$(search)"
      },
      {
        "command": "redmine.searchProjects",
        "title": "Redmine: 프로젝트 일감 검색",
        "icon": "$(search)"
      },
      {
        "command": "redmine.newIssue",
        "title": "Redmine: 새 일감",
        "icon": "$(add)"
      },
      {
        "command": "redmine.setApiKey",
        "title": "Redmine: Set API Key"
      },
      {
        "command": "redmine.openIssue",
        "title": "Redmine: 일감 열기"
      },
      {
        "command": "redmine.openIssueInBrowser",
        "title": "Redmine: 브라우저에서 열기",
        "icon": "$(link-external)"
      },
      {
        "command": "redmine.issuesForFile",
        "title": "Redmine: 이 파일 관련 일감"
      },
      {
        "command": "redmine.downloadIssues",
        "title": "일감 다운로드 (issue.md + 첨부)"
      },
      {
        "command": "redmine.openIssueByNumber",
        "title": "Redmine: #번호로 열기",
        "icon": "$(symbol-number)"
      },
      {
        "command": "redmine.toggleMyIssuesGroupBy",
        "title": "Redmine: 내 일감 그룹 기준 변경",
        "icon": "$(list-tree)"
      },
      {
        "command": "redmine.changeStatus",
        "title": "Redmine: 상태 변경…",
        "icon": "$(check)"
      },
      {
        "command": "redmine.reopenIssue",
        "title": "Redmine: 재오픈",
        "icon": "$(issue-reopened)"
      },
      {
        "command": "redmine.copyIssueLink",
        "title": "Redmine: 링크 복사",
        "icon": "$(copy)"
      },
      {
        "command": "redmine.showChangesets",
        "title": "Redmine: 연결 커밋 보기",
        "icon": "$(git-commit)"
      },
      {
        "command": "redmine.myIssues.more",
        "title": "Redmine: 더 보기"
      },
      {
        "command": "redmine.projects.more",
        "title": "Redmine: 더 보기"
      },
      {
        "command": "redmine.openPanel",
        "title": "Redmine: 패널을 에디터 탭으로 열기",
        "icon": "$(link-external)"
      },
      {
        "command": "redmine.openPanelTime",
        "title": "Redmine: 소요시간 패널 열기",
        "icon": "$(watch)"
      },
      {
        "command": "redmine.refreshPanel",
        "title": "Redmine: 패널 새로고침",
        "icon": "$(refresh)"
      },
      {
        "command": "redmine.insertIssueRef",
        "title": "Redmine: 커밋에 일감 #번호 삽입",
        "icon": "$(references)"
      },
      {
        "command": "redmine.diffCommitFile",
        "title": "Redmine: 커밋 파일 diff"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "redmine.searchMyIssues",
          "when": "view == redmineMyIssues",
          "group": "navigation@1"
        },
        {
          "command": "redmine.openIssueByNumber",
          "when": "view == redmineMyIssues",
          "group": "navigation@2"
        },
        {
          "command": "redmine.toggleMyIssuesGroupBy",
          "when": "view == redmineMyIssues",
          "group": "navigation@3"
        },
        {
          "command": "redmine.refresh",
          "when": "view == redmineMyIssues",
          "group": "navigation@4"
        },
        {
          "command": "redmine.searchProjects",
          "when": "view == redmineProjects",
          "group": "navigation@1"
        },
        {
          "command": "redmine.refresh",
          "when": "view == redmineProjects",
          "group": "navigation@2"
        },
        {
          "command": "redmine.refreshPanel",
          "when": "view == redminePanel",
          "group": "navigation@1"
        },
        {
          "command": "redmine.openPanel",
          "when": "view == redminePanel",
          "group": "navigation@2"
        }
      ],
      "scm/title": [
        {
          "command": "redmine.insertIssueRef",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "redmine.openIssueInBrowser",
          "when": "viewItem =~ /redmine:issue/",
          "group": "inline@1"
        },
        {
          "command": "redmine.changeStatus",
          "when": "viewItem =~ /redmine:issue\\+open/",
          "group": "inline@2"
        },
        {
          "command": "redmine.reopenIssue",
          "when": "viewItem =~ /redmine:issue\\+closed/",
          "group": "inline@2"
        },
        {
          "command": "redmine.changeStatus",
          "when": "viewItem =~ /redmine:issue\\+open/",
          "group": "1_redmine_actions@1"
        },
        {
          "command": "redmine.downloadIssues",
          "when": "viewItem =~ /redmine:issue/",
          "group": "2_redmine_explore@1"
        },
        {
          "command": "redmine.showChangesets",
          "when": "viewItem =~ /redmine:issue\\+open/",
          "group": "2_redmine_explore@2"
        },
        {
          "command": "redmine.copyIssueLink",
          "when": "viewItem =~ /redmine:issue/",
          "group": "3_redmine_share@1"
        },
        {
          "command": "redmine.openIssueInBrowser",
          "when": "viewItem =~ /redmine:issue/",
          "group": "3_redmine_share@2"
        }
      ],
      "explorer/context": [
        {
          "command": "redmine.issuesForFile",
          "when": "!explorerResourceIsFolder",
          "group": "z_redmine"
        }
      ],
      "editor/context": [
        {
          "command": "redmine.issuesForFile",
          "group": "z_redmine"
        }
      ],
      "commandPalette": [
        {
          "command": "redmine.openIssue",
          "when": "false"
        },
        {
          "command": "redmine.openIssueInBrowser",
          "when": "false"
        },
        {
          "command": "redmine.downloadIssues",
          "when": "false"
        },
        {
          "command": "redmine.changeStatus",
          "when": "false"
        },
        {
          "command": "redmine.reopenIssue",
          "when": "false"
        },
        {
          "command": "redmine.copyIssueLink",
          "when": "false"
        },
        {
          "command": "redmine.showChangesets",
          "when": "false"
        },
        {
          "command": "redmine.myIssues.more",
          "when": "false"
        },
        {
          "command": "redmine.projects.more",
          "when": "false"
        },
        {
          "command": "redmine.diffCommitFile",
          "when": "false"
        },
        {
          "command": "redmine.openPanelTime",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Redmine",
      "properties": {
        "redmine.url": {
          "type": "string",
          "default": "",
          "description": "Redmine 서버 URL (https://...)"
        },
        "redmine.projectIdentifier": {
          "type": "string",
          "default": "",
          "description": "프로젝트 identifier (선택, '내 일감' 범위 한정용)"
        },
        "redmine.downloadPath": {
          "type": "string",
          "default": "",
          "description": "일감 다운로드 기본 경로. 절대경로/~ 또는 상대경로(워크스페이스 기준). 비우면 매번 위치 선택"
        },
        "redmine.views.myIssues.groupBy": {
          "type": "string",
          "enum": ["project", "status", "none"],
          "default": "project",
          "description": "'내 일감' 트리 그룹 기준 (프로젝트/상태/그룹없음)"
        },
        "redmine.sidebar.showTodayTime": {
          "type": "boolean",
          "default": true,
          "description": "사이드바 상단 '오늘 소요시간' 스트립 표시 (끄면 트리만 표시)"
        },
        "redmine.panel.showBadge": {
          "type": "boolean",
          "default": true,
          "description": "패널 탭 배지 표시 — 기한 임박 + 지연 일감 수"
        },
        "redmine.commits.linkedOnly": {
          "type": "boolean",
          "default": false,
          "description": "커밋 뷰에서 일감(#번호) 연결 커밋만 기본 표시 (뷰에서 일시 전환 가능)"
        },
        "redmine.search.defaultAssignee": {
          "type": "string",
          "enum": ["me", "all"],
          "default": "me",
          "description": "일감 검색 기본 담당자 (나/전체)"
        },
        "redmine.search.defaultStatus": {
          "type": "string",
          "enum": ["open", "all"],
          "default": "open",
          "description": "일감 검색 기본 상태 (진행 중만/전체)"
        },
        "redmine.search.defaultSort": {
          "type": "string",
          "enum": ["updated", "due", "priority"],
          "default": "updated",
          "description": "일감 검색 기본 정렬 (수정일/기한/우선순위)"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "typecheck": "tsc --noEmit && svelte-check --tsconfig src/webviewUi/tsconfig.json"
  },
  "dependencies": {
    "@redmine-tools/core": "*"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.24.0",
    "esbuild-svelte": "0.9.5",
    "svelte": "5.56.4",
    "svelte-check": "4.7.2",
    "typescript": "^5.5.0"
  }
}
