{
  "manifest_version": "0.2",
  "name": "redmine",
  "display_name": "Redmine",
  "version": "0.2.0",
  "description": "Redmine 일감 — 목록/상세/상태변경/댓글/내보내기",
  "author": {
    "name": "bizhost"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bizhost/redmine-vscode"
  },
  "server": {
    "type": "node",
    "entry_point": "server/index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/server/index.js"],
      "env": {
        "REDMINE_URL": "${user_config.redmine_url}",
        "REDMINE_API_KEY": "${user_config.api_key}",
        "REDMINE_PROJECT": "${user_config.project}"
      }
    }
  },
  "user_config": {
    "redmine_url": {
      "type": "string",
      "title": "Redmine 서버 URL",
      "description": "예: https://redmine.example.com",
      "required": true
    },
    "api_key": {
      "type": "string",
      "title": "API Key",
      "description": "Redmine → 내 계정 → API 접근키",
      "sensitive": true,
      "required": true
    },
    "project": {
      "type": "string",
      "title": "프로젝트 identifier (선택)",
      "description": "비우면 전체 프로젝트",
      "required": false,
      "default": ""
    }
  }
}
